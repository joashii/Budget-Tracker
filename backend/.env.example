# --- Server ---
PORT=4000
SESSION_SECRET=change-me-to-something-random-and-long
NODE_ENV=development

# --- Google OAuth2 (multi-user) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

SPREADSHEET_NAME=Budget Tracker — My Data

# --- Frontend URL (post-login redirect target + CORS allow-origin) ---
APP_URL=http://localhost:5173

# --- Email reminders (Nodemailer / Gmail SMTP example) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# --- Vercel KV (only needed when deployed - leave blank for local dev) ---
# Auto-filled by Vercel when you attach a KV store to the project; copy from
# Vercel dashboard -> Storage -> your KV store -> .env.local tab if running
# `vercel env pull` locally against a KV-backed deployment.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Vercel Cron protection ---
# Set this on Vercel (Project Settings -> Environment Variables). Vercel sends
# it back as "Authorization: Bearer <value>" automatically on cron-triggered
# requests, so /api/cron/reminders can verify the request really came from Vercel.
CRON_SECRET=
